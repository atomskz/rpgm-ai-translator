{
  "name": "rpgm-ai-translator",
  "version": "0.1.5",
  "description": "AI-assisted translation pipeline for RPG Maker MV/MZ games.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "rpgm-ai-translator": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "rpg-maker",
    "translation",
    "llm",
    "deepseek"
  ],
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/atomskz/rpgm-ai-translator.git"
  },
  "bugs": {
    "url": "https://github.com/atomskz/rpgm-ai-translator/issues"
  },
  "homepage": "https://github.com/atomskz/rpgm-ai-translator#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.10",
    "eslint": "^10.5.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
